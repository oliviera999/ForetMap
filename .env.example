# ForetMap — variables d'environnement (copier en .env, ne pas commiter .env)
# Production (o2switch) : définir ces variables dans l'interface "Setup Node.js App"

# Base de données MySQL
DB_HOST=localhost
DB_PORT=3306
DB_NAME=oliviera_foretmap
DB_USER=oliviera_foretmap
DB_PASS=votre_mot_de_passe
# Taille du pool mysql2 (défaut 30, max 100). Ajuster selon max_connections MySQL de l’hébergeur.
# FORETMAP_DB_CONNECTION_LIMIT=30

# Serveur
PORT=3000
NODE_ENV=production
# Taille max des corps JSON/urlencoded (ex. photos base64 sur forum / commentaires). Défaut 100mb si absent.
# FORETMAP_JSON_BODY_LIMIT=100mb

# Limite express-rate-limit sur /api/* (requêtes / minute / IP). Défaut 1200 si absent — augmente si beaucoup d’élèves derrière la même IP (Wi‑Fi).
# FORETMAP_API_RATE_LIMIT_PER_MIN=1200

# Logs (Pino) : en dev sans variable = niveau debug ; en production = info.
# LOG_LEVEL=debug
# Socket.IO : erreurs Engine.IO « Session ID unknown » (reconnexion) en niveau debug côté serveur pour limiter le bruit en warn.
# (Debug) Si =1 : sur échec PUT /api/tasks/:id, les profs avec tasks.manage reçoivent debugDetail/debugCode dans le JSON 500.
# FORETMAP_DEBUG_TASK_PUT_CLIENT=

# HTTP : off | minimal (défaut prod : 5xx + requêtes lentes) | full (bruyant).
# FORETMAP_HTTP_LOG=minimal
# Seuil « lent » (ms) pour minimal (défaut 8000).
# FORETMAP_HTTP_SLOW_MS=8000
# Probabilité 0–1 de loguer un 429 rate limit (défaut 0.01), IP tronquée.
# FORETMAP_RATE_LIMIT_LOG_SAMPLE=0.01

# Auth / RBAC
# JWT_SECRET est requis en production.
# TEACHER_PIN reste optionnel comme mode secours historique (admin).
TEACHER_PIN=1234
JWT_SECRET=changez_moi_en_production_secret_long_aleatoire

# Visite guidée (progression anonyme) : signature HMAC du cookie anon_visit_token.
# En production, définir une valeur dédiée (longue, aléatoire). Sinon repli sur JWT_SECRET puis secret de dev si NODE_ENV ≠ production.
# VISIT_COOKIE_SECRET=

# Compte prof email/mot de passe (optionnel, auto-seed au premier usage)
# TEACHER_ADMIN_EMAIL=prof@exemple.com
# TEACHER_ADMIN_PASSWORD=mot_de_passe_prof
# TEACHER_ADMIN_DISPLAY_NAME=Professeur

# RBAC : rôle élève par défaut à l'inscription (eleve_novice|eleve_avance|eleve_chevronne)
# RBAC_DEFAULT_STUDENT_ROLE=eleve_novice

# CORS (production) : origine autorisée du frontend
# FRONTEND_ORIGIN=https://foretmap.olution.info

# OAuth2 Google (optionnel) : connexion via comptes Google autorisés
# GOOGLE_OAUTH_CLIENT_ID=567947229654-c48g21orojrq20aofo6glheon95hummt.apps.googleusercontent.com
# GOOGLE_OAUTH_CLIENT_SECRET=votre_secret_google
# GOOGLE_OAUTH_REDIRECT_URI=https://foretmap.olution.info/api/auth/google/callback
# Domaines autorisés (CSV)
# GOOGLE_OAUTH_ALLOWED_DOMAINS=pedagolyautey.org,lyceelyautey.org
# Emails autorisés explicitement (CSV)
# GOOGLE_OAUTH_ALLOWED_EMAILS=oliv.arn.lau@gmail.com

# Reset mot de passe (lien envoyé par email)
# PASSWORD_RESET_BASE_URL=https://foretmap.olution.info

# SMTP pour envoi d'emails (mot de passe oublié)
# SMTP_HOST=smtp.exemple.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=utilisateur_smtp
# SMTP_PASS=mot_de_passe_smtp
# SMTP_FROM="ForetMap <no-reply@exemple.com>"
# SMTP_JSON_TRANSPORT=true

# --- Déploiement / admin distant (prod) ---
# Sur le serveur : uniquement DEPLOY_SECRET (obligatoire pour restart, logs, diagnostics).
# En local (.env non versionné), pour debug distant vous pouvez définir la même valeur sous 1 à 3 noms :
#   DEPLOY_SECRET              → canonique (aligné serveur) ; lu par deploy:check, prod:admin-tail, prod:remote-debug
#   FORETMAP_DEPLOY_CHECK_SECRET → alias pour les scripts npm ci-dessus
#   FORETMAP_DEPLOY_SECRET     → lu par Cursor MCP (foretmap-diagnostics) ; fallback DEPLOY_SECRET si défini dans l’env MCP
# Commandes utiles : npm run deploy:check:prod | prod:admin-diagnostics | prod:admin-tail | prod:remote-debug
# URL cible locale → distante : FORETMAP_PROD_BASE_URL=https://foretmap.olution.info
# Redémarrage : POST /api/admin/restart avec header X-Deploy-Secret: <valeur>
# Logs tampon Pino : GET /api/admin/logs (même header) ; diag : GET /api/admin/diagnostics
# DEPLOY_SECRET=un_secret_long_aleatoire
# FORETMAP_DEPLOY_CHECK_SECRET=meme_valeur_que_deploy_secret
# FORETMAP_DEPLOY_SECRET=meme_valeur_que_deploy_secret

# Optionnel : taille du tampon de lignes pour GET /api/admin/logs (100–5000, défaut 2000)
# LOG_BUFFER_MAX_LINES=2000

# Optionnel (écoute)
# IP=0.0.0.0

# --- Pré-saisie biodiversité (extensions optionnelles, désactivées par défaut) ---
# Voir docs/SPECIES_AUTOFILL_EXTENSIONS.md — Wikipedia / GBIF / Wikidata : sources publiques, pas de clé ici.
# API Trefle (plantes) : sans les deux variables, aucun appel.
# TREFLE_TOKEN=
# SPECIES_AUTOFILL_TREFLE=1
# OpenAI (complément LLM serveur) : sans OPENAI_API_KEY et SPECIES_AUTOFILL_OPENAI=1, aucun appel.
# OPENAI_API_KEY=
# SPECIES_AUTOFILL_OPENAI=1
# SPECIES_AUTOFILL_OPENAI_MODEL=gpt-4o-mini
# Pl@ntNet (alignement + espèces / images optionnelles) : sans clé et SPECIES_AUTOFILL_PLANTNET=1, aucun appel.
# PLANTNET_API_KEY=
# SPECIES_AUTOFILL_PLANTNET=1
# PLANTNET_PROJECT=k-world-flora
# PLANTNET_LANG=fr
# PLANTNET_ALIGN_AUTHORSHIP=0
# SPECIES_AUTOFILL_PLANTNET_NO_IMAGES=1
