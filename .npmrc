# En local/CI, installer aussi les dépendances de développement.
# Les scripts de déploiement production utilisent déjà explicitement --omit=dev.

# Artillery (charge, dev) tire @opentelemetry/api@1.4.x ; Vitest 4 déclare un peer
# optionnel ^1.9.0 → ERESOLVE sur npm install strict. legacy-peer-deps : conflit
# limité aux devDependencies, sans impact runtime prod (--omit=dev).
legacy-peer-deps=true
