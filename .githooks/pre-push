#!/bin/sh
# Pre-push ForetMap — empêche de pousser des modifications frontend sans dist/ régénéré.
# Reproduit le garde-fou de scripts/auto-deploy-cron.sh, mais AVANT le push : le serveur
# ne rejettera donc jamais le déploiement pour cause de dist/ périmé.
# Forcer (déconseillé) : git push --no-verify
#
# Activé via core.hooksPath=.githooks (script npm `prepare` → scripts/setup-git-hooks.js).

z40=0000000000000000000000000000000000000000
FRONTEND='^(src/|index\.vite\.html$|vite\.config\.js$|public/)'
fail=0

while read -r local_ref local_sha remote_ref remote_sha; do
  # Suppression de branche (rien à pousser côté contenu).
  [ "$local_sha" = "$z40" ] && continue

  if [ "$remote_sha" = "$z40" ]; then
    # Nouvelle branche : borne le diff sur l'ancêtre commun avec origin/main
    # (sinon on inspecterait tout l'historique). Si introuvable, on s'abstient.
    base=$(git merge-base "$local_sha" origin/main 2>/dev/null) || base=""
    [ -z "$base" ] && continue
    range="$base..$local_sha"
  else
    range="$remote_sha..$local_sha"
  fi

  changed=$(git diff --name-only "$range" 2>/dev/null)
  [ -z "$changed" ] && continue

  if printf '%s\n' "$changed" | grep -Eq "$FRONTEND"; then
    if ! printf '%s\n' "$changed" | grep -Eq '^dist/'; then
      echo "" >&2
      echo "✖ pre-push: modifications frontend détectées ($range) sans mise à jour de dist/." >&2
      echo "  Lance 'npm run build' (ou 'npm run ship') puis recommite dist/ avant de pousser." >&2
      fail=1
    fi
  fi
done

if [ "$fail" -ne 0 ]; then
  echo "" >&2
  echo "Push bloqué par le hook pre-push (cf. garde-fou frontend du cron)." >&2
  exit 1
fi
exit 0
