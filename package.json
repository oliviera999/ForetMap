{
  "name": "foretmap",
  "version": "1.28.26",
  "description": "Application de gestion de la forêt comestible - Lycée Lyautey",
  "main": "server.js",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.1",
    "google-auth-library": "^10.6.2",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.6.5",
    "nodemailer": "^8.0.4",
    "on-finished": "^2.4.1",
    "pdfkit": "^0.18.0",
    "pino": "^8.17.2",
    "socket.io": "^4.8.1",
    "uuid": "^9.0.0",
    "xlsx": "^0.18.5"
  },
  "scripts": {
    "start": "node server.js",
    "start:e2e": "node server.js --foretmap-e2e-no-rate-limit",
    "dev": "nodemon server.js",
    "dev:client": "vite",
    "debug": "node --inspect server.js",
    "debug:dev": "nodemon --inspect server.js",
    "db:init": "node -e \"require('dotenv').config(); const { initSchema, seedData } = require('./database'); (async () => { await initSchema(); await seedData(); console.log('DB init OK'); process.exit(0); })()\"",
    "db:migrate": "node -e \"require('dotenv').config(); const { initSchema } = require('./database'); (async () => { await initSchema(); console.log('Migrations OK'); process.exit(0); })()\"",
    "db:seed:teacher": "node scripts/seed-teacher-admin.js",
    "db:import:dump": "node scripts/import-foretmap-dump.js",
    "db:reset:role-pins:local": "node scripts/reset-local-role-pins-from-env.js",
    "db:admin:audit": "node scripts/ensure-admin-and-audit-db.js --login oliviera9",
    "db:admin:audit:dry": "node scripts/ensure-admin-and-audit-db.js --login oliviera9 --dry-run",
    "db:admin:audit:fix-orphans": "node scripts/ensure-admin-and-audit-db.js --login oliviera9 --fix-orphans",
    "db:collective:cleanup:audit": "node scripts/cleanup-collective-and-audit-db-structure.js",
    "db:collective:cleanup:audit:dry": "node scripts/cleanup-collective-and-audit-db-structure.js --dry-run",
    "db:cleanup:dev:dry": "node scripts/cleanup-dev-data.js --dry-run",
    "db:cleanup:dev": "node scripts/cleanup-dev-data.js --apply",
    "db:backfill:users": "node scripts/backfill-users-unification.js",
    "db:migrate:images": "node scripts/migrate-images-to-disk.js",
    "db:migrate:images:dry": "node scripts/migrate-images-to-disk.js --dry-run",
    "db:migrate:images:clear": "node scripts/migrate-images-to-disk.js --clear-legacy",
    "db:migrate:images:report": "node scripts/image-migration-report.js",
    "db:uploads:reconcile:dry": "node scripts/reconcile-orphan-uploads.js",
    "db:uploads:reconcile": "node scripts/reconcile-orphan-uploads.js --apply",
    "db:plants:photos:direct:dry": "node scripts/resolve-plants-photo-direct-links.js",
    "db:plants:photos:direct": "node scripts/resolve-plants-photo-direct-links.js --write",
    "db:plants:sources:consolidate:dry": "node scripts/consolidate-plants-sources.js",
    "db:plants:sources:consolidate": "node scripts/consolidate-plants-sources.js --write",
    "migrate:sqlite-to-mysql": "node scripts/migrate-sqlite-to-mysql.js",
    "bump:patch": "npm version patch --no-git-tag-version",
    "bump:minor": "npm version minor --no-git-tag-version",
    "bump:major": "npm version major --no-git-tag-version",
    "release:patch": "npm version patch -m \"chore(release): v%s\"",
    "release:minor": "npm version minor -m \"chore(release): v%s\"",
    "release:major": "npm version major -m \"chore(release): v%s\"",
    "test": "node --test --test-concurrency=1 --test-force-exit \"tests/*.test.js\"",
    "test:local": "cross-env DB_NAME=foretmap_test node scripts/test-local-isolated.js",
    "test:load": "node scripts/run-load-test.js normal",
    "test:load:light": "node scripts/run-load-test.js light",
    "test:load:normal": "node scripts/run-load-test.js normal",
    "test:load:stress": "node scripts/run-load-test.js stress",
    "test:load:10vu": "node scripts/run-load-test.js 10vu",
    "test:load:socketio-smoke": "node scripts/load-socketio-polling-smoke.js",
    "test:load:all": "node scripts/run-load-scenarios.js",
    "test:load:report": "node scripts/render-load-report.js",
    "test:e2e": "node scripts/e2e-kill-listen-port.js && npx playwright test",
    "test:e2e:headed": "node scripts/e2e-kill-listen-port.js && npx playwright test --headed",
    "test:snapshot": "cross-env FORETMAP_SNAPSHOT_TESTS=1 node --test --test-force-exit tests/snapshot-db.test.js",
    "docker:up": "docker compose up -d || docker-compose up -d",
    "docker:down": "docker compose down || docker-compose down",
    "local:setup": "npm run docker:up && npm install --include=dev && node scripts/wait-mysql-ready.js && npm run db:init && npm run check:local",
    "check:local": "node scripts/check-local-env.js",
    "smoke:local": "node scripts/local-smoke.js",
    "smoke:local:fast": "node scripts/local-smoke.js --fast",
    "icons:pwa": "node scripts/generate-pwa-icons-n3-white.js",
    "build": "node scripts/build-safe.js",
    "preview": "vite preview",
    "deploy:prepare": "node scripts/prepare-dist-deploy.js",
    "deploy:prepare:fast": "node scripts/prepare-dist-deploy.js --skip-install",
    "deploy:prepare:runtime": "powershell -ExecutionPolicy Bypass -File scripts/prepare-runtime-deploy.ps1",
    "deploy:prepare:runtime:fast": "powershell -ExecutionPolicy Bypass -File scripts/prepare-runtime-deploy.ps1 -SkipInstall -SkipBuild",
    "deploy:check": "node scripts/post-deploy-check.js",
    "deploy:check:prod": "node scripts/post-deploy-check.js --base-url https://foretmap.olution.info",
    "tasks:spawn-recurring": "node scripts/spawn-recurring-tasks.js",
    "mcp:diag": "node scripts/mcp-foretmap-diagnostics.mjs",
    "prod:admin-tail": "node scripts/prod-admin-tail.js",
    "prod:admin-diagnostics": "node scripts/prod-admin-diagnostics.js",
    "prod:remote-debug": "node scripts/prod-remote-debug.js"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@playwright/test": "^1.58.2",
    "@vitejs/plugin-react": "^4.2.1",
    "artillery": "^2.0.30",
    "cross-env": "^7.0.3",
    "nodemon": "^3.0.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "sharp": "^0.34.5",
    "socket.io-client": "^4.8.1",
    "supertest": "^6.3.4",
    "vite": "^5.0.10",
    "zod": "^4.3.6"
  }
}
