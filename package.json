{
  "name": "foretmap",
  "version": "1.84.0",
  "description": "Application de gestion de la forêt comestible - Lycée Lyautey",
  "main": "server.js",
  "engines": {
    "node": ">=20.19"
  },
  "dependencies": {
    "adm-zip": "^0.5.18",
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "google-auth-library": "^10.9.0",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.2.0",
    "mysql2": "^3.22.5",
    "nodemailer": "^9.0.3",
    "on-finished": "^2.4.1",
    "pdfkit": "^0.19.1",
    "pino": "^10.3.1",
    "socket.io": "^4.8.1",
    "zod": "^4.4.3"
  },
  "optionalDependencies": {
    "sharp": "^0.35.3"
  },
  "overrides": {
    "engine.io": {
      "ws": "^8.21.0"
    },
    "engine.io-client": {
      "ws": "^8.21.0"
    },
    "socket.io-adapter": {
      "ws": "^8.21.0"
    }
  },
  "scripts": {
    "prepare": "node scripts/setup-git-hooks.js || exit 0",
    "start": "node server.js",
    "start:e2e": "node server.js --foretmap-e2e-no-rate-limit",
    "dev": "nodemon server.js",
    "dev:client": "vite",
    "debug": "node --inspect server.js",
    "debug:dev": "nodemon --inspect server.js",
    "db:init": "node -e \"require('dotenv').config(); const { initSchema, seedData } = require('./database'); (async () => { await initSchema(); await seedData(); console.log('DB init OK'); process.exit(0); })()\"",
    "db:migrate": "node -e \"require('dotenv').config(); const { initSchema } = require('./database'); (async () => { await initSchema(); console.log('Migrations OK'); process.exit(0); })()\"",
    "learning:suggest-links": "node scripts/suggest-learning-links.js",
    "learning:generate-questions": "node scripts/generate-linked-questions.js",
    "db:seed:teacher": "node scripts/seed-teacher-admin.js",
    "db:import:dump": "node scripts/import-foretmap-dump.js",
    "db:admin:audit": "node scripts/ensure-admin-and-audit-db.js",
    "db:admin:audit:dry": "node scripts/ensure-admin-and-audit-db.js --dry-run",
    "db:admin:audit:fix-orphans": "node scripts/ensure-admin-and-audit-db.js --fix-orphans",
    "db:collective:cleanup:audit": "node scripts/cleanup-collective-and-audit-db-structure.js",
    "db:collective:cleanup:audit:dry": "node scripts/cleanup-collective-and-audit-db-structure.js --dry-run",
    "db:cleanup:dev:dry": "node scripts/cleanup-dev-data.js --dry-run",
    "db:cleanup:dev": "node scripts/cleanup-dev-data.js --apply",
    "db:backfill:users": "node scripts/backfill-users-unification.js",
    "db:migrate:images": "node scripts/migrate-images-to-disk.js",
    "db:migrate:images:dry": "node scripts/migrate-images-to-disk.js --dry-run",
    "db:migrate:images:clear": "node scripts/migrate-images-to-disk.js --clear-legacy",
    "db:migrate:images:report": "node scripts/image-migration-report.js",
    "db:uploads:reconcile:dry": "node scripts/reconcile-orphan-uploads.js",
    "db:uploads:reconcile": "node scripts/reconcile-orphan-uploads.js --apply",
    "db:plants:photos:direct:dry": "node scripts/resolve-plants-photo-direct-links.js",
    "db:plants:photos:direct": "node scripts/resolve-plants-photo-direct-links.js --write",
    "db:plants:sources:consolidate:dry": "node scripts/consolidate-plants-sources.js",
    "db:plants:sources:consolidate": "node scripts/consolidate-plants-sources.js --write",
    "migrate:sqlite-to-mysql": "node scripts/migrate-sqlite-to-mysql.js",
    "export:sqlite-garden": "node scripts/export-sqlite-garden-sql.js",
    "bump:patch": "npm version patch --no-git-tag-version",
    "bump:minor": "npm version minor --no-git-tag-version",
    "bump:major": "npm version major --no-git-tag-version",
    "release:patch": "npm version patch -m \"chore(release): v%s\"",
    "release:minor": "npm version minor -m \"chore(release): v%s\"",
    "release:major": "npm version major -m \"chore(release): v%s\"",
    "test": "node --test --test-concurrency=1 --test-force-exit tests/*.test.js",
    "test:coverage": "node --test --experimental-test-coverage --test-concurrency=1 --test-force-exit tests/*.test.js",
    "test:ui": "vitest run --config vitest.config.js",
    "test:ui:watch": "vitest --config vitest.config.js",
    "test:ui:coverage": "vitest run --coverage --config vitest.config.js",
    "test:all": "npm test && npm run test:ui",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test:local": "cross-env DB_NAME=foretmap_test node scripts/test-local-isolated.js",
    "test:load": "node scripts/run-load-test.js normal",
    "test:load:light": "node scripts/run-load-test.js light",
    "test:load:stress": "node scripts/run-load-test.js stress",
    "test:load:gl": "artillery run load/artillery-gl.yml --output load/report-gl.json",
    "test:load:10vu": "node scripts/run-load-test.js 10vu",
    "test:load:socketio-smoke": "node scripts/load-socketio-polling-smoke.js",
    "test:load:all": "node scripts/run-load-scenarios.js",
    "test:load:report": "node scripts/render-load-report.js",
    "test:e2e": "node scripts/e2e-kill-listen-port.js && npx playwright test",
    "test:e2e:clean": "npm run clean:tests && npm run test:e2e",
    "test:e2e:headed": "node scripts/e2e-kill-listen-port.js && npx playwright test --headed",
    "test:e2e:headed:clean": "npm run clean:tests && npm run test:e2e:headed",
    "test:snapshot": "cross-env FORETMAP_SNAPSHOT_TESTS=1 node --test --test-force-exit tests/snapshot-db.test.js",
    "test:snapshot:gl": "cross-env FORETMAP_SNAPSHOT_GL=1 node --test --test-force-exit tests/snapshot-gl.test.js",
    "clean:tests": "node scripts/clean-local-artifacts.js --tests",
    "clean:load": "node scripts/clean-local-artifacts.js --load",
    "clean:local": "node scripts/clean-local-artifacts.js --tests --load",
    "docker:up": "docker compose up -d || docker-compose up -d",
    "docker:down": "docker compose down || docker-compose down",
    "local:setup": "npm run docker:up && npm install --include=dev && node scripts/wait-mysql-ready.js && npm run db:init && npm run check:local",
    "check:local": "node scripts/check-local-env.js",
    "smoke:local": "node scripts/local-smoke.js",
    "smoke:local:fast": "node scripts/local-smoke.js --fast",
    "icons:pwa": "node scripts/generate-pwa-icons-n3-white.js",
    "icons:gl": "node scripts/generate-gl-icons.js",
    "fonts:sync-noto-emoji": "node scripts/sync-noto-color-emoji-font.js",
    "mascot:fox-backpack": "node scripts/fox-backpack-extract-and-compose.cjs",
    "mascot:renard2-cut": "node scripts/renard2-cut-extract.cjs",
    "mascot:renard2-cut-align-walk": "node scripts/renard2-cut-align-walk.cjs",
    "mascot:gnome1-cut": "node scripts/gnome1-cut-extract.cjs",
    "mascot:gnome1-pack": "node scripts/gnome1-pack-archive.cjs",
    "mascot:pack:validate": "node scripts/mascot-pack-validate.cjs",
    "sync:visit-pack-lib": "node scripts/sync-visit-pack-server-lib.js",
    "sync:gl-pack-lib": "node scripts/sync-gl-pack-server-lib.js",
    "build": "node scripts/build-safe.js",
    "ship": "node scripts/build-ship.js",
    "preview": "vite preview",
    "deploy:prepare": "node scripts/prepare-dist-deploy.js",
    "deploy:prepare:fast": "node scripts/prepare-dist-deploy.js --skip-install",
    "deploy:prepare:runtime": "node scripts/prepare-runtime-deploy.js",
    "deploy:prepare:runtime:fast": "node scripts/prepare-runtime-deploy.js --skip-install --skip-build",
    "deploy:prepare:runtime:selector": "node scripts/prepare-runtime-deploy.js --cloudlinux-selector",
    "deploy:prepare:runtime:selector:fast": "node scripts/prepare-runtime-deploy.js --cloudlinux-selector --skip-install --skip-build --skip-prune",
    "deploy:prepare:runtime:ps": "powershell -ExecutionPolicy Bypass -File scripts/prepare-runtime-deploy.ps1",
    "deploy:prepare:runtime:fast:ps": "powershell -ExecutionPolicy Bypass -File scripts/prepare-runtime-deploy.ps1 -SkipInstall -SkipBuild",
    "deploy:prepare:runtime:selector:ps": "powershell -ExecutionPolicy Bypass -File scripts/prepare-runtime-deploy.ps1 -CloudlinuxSelector",
    "deploy:prepare:runtime:selector:fast:ps": "powershell -ExecutionPolicy Bypass -File scripts/prepare-runtime-deploy.ps1 -CloudlinuxSelector -SkipInstall -SkipBuild -SkipPrune",
    "deploy:check": "node scripts/post-deploy-check.js",
    "deploy:check:prod": "node scripts/post-deploy-check.js --base-url https://foretmap.olution.info --gl-base-url https://gl.olution.info",
    "deploy:check:prod:foret": "node scripts/post-deploy-check.js --base-url https://foretmap.olution.info",
    "gl:import:wp": "node scripts/gl-import-wp.js",
    "gl:import:species": "node scripts/gl-import-species.js",
    "gl:import:spells": "node scripts/gl-import-spells.js",
    "gl:import:glossary": "node scripts/gl-import-glossary.js",
    "gl:import:qcm": "node scripts/gl-import-qcm.js",
    "gl:import:qcm-lore": "node scripts/gl-import-qcm-lore.js",
    "gl:import:chapters": "node scripts/gl-import-chapters.js",
    "gl:import:chapters:example": "node scripts/gl-import-chapters.js --write-example",
    "gl:import:lore-feuillets": "node scripts/gl-import-lore-feuillets.js",
    "gl:import:lore-glossary": "node scripts/gl-import-lore-glossary.js",
    "gl:intro:debundle": "node scripts/gl-intro-debundle.js",
    "gl:build:assets": "node scripts/build-asset-manifest.mjs",
    "gl:import:media": "node scripts/import-gl-media-local.mjs",
    "gl:audit:media-keys": "node scripts/audit-gl-media-keys.mjs",
    "gl:audit:feuillet-coverage": "python3 scripts/gl-audit-feuillet-coverage.py",
    "gl:migrate:chapter-media": "node scripts/migrate-gl-chapter-media-urls.js",
    "tasks:spawn-recurring": "node scripts/spawn-recurring-tasks.js",
    "mcp:diag": "node scripts/mcp-foretmap-diagnostics.mjs",
    "prod:admin-tail": "node scripts/prod-admin-tail.js",
    "prod:admin-diagnostics": "node scripts/prod-admin-diagnostics.js",
    "prod:remote-debug": "node scripts/prod-remote-debug.js",
    "prod:transport-probe": "node scripts/prod-transport-probe.mjs",
    "db:import:biodiv": "node scripts/import-biodiv-pedago.js && node scripts/import-plants-enriched.js"
  },
  "devDependencies": {
    "@fontsource/noto-color-emoji": "^5.2.12",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@playwright/test": "^1.61.1",
    "@rive-app/react-canvas": "^4.29.4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/ui": "^4.1.9",
    "artillery": "^2.0.33",
    "better-sqlite3": "^12.11.1",
    "cross-env": "^10.1.0",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "isomorphic-dompurify": "^3.18.0",
    "jsdom": "^29.1.1",
    "marked": "^18.0.5",
    "nodemon": "^3.0.2",
    "prettier": "^3.9.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "socket.io-client": "^4.8.1",
    "supertest": "^7.2.2",
    "turndown": "^7.2.4",
    "vite": "^8.1.3",
    "vitest": "^4.1.9",
    "xlsx": "^0.18.5"
  }
}
