# ForetMap — copier vers .env pour le dev local avec Docker (voir docs/LOCAL_DEV.md)
# Ne pas utiliser ces identifiants en production (o2switch).

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=foretmap_local
DB_USER=root
DB_PASS=foretmap_local_root

PORT=3000
NODE_ENV=development

TEACHER_PIN=1234
JWT_SECRET=dev_jwt_secret_local_only

# Optionnel : CORS proche prod (sinon CORS permissif en dev)
# FRONTEND_ORIGIN=http://localhost:3000
